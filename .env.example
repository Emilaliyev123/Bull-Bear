PORT=3000
# Use https://staging.bullandbear.az for staging and https://bullandbear.az for production.
APP_URL=https://staging.bullandbear.az
# On Render, set this to the mounted persistent disk path so uploads and db.json survive deploys.
STORAGE_DIR=/var/data
ADMIN_USERNAME=admin
# Required. Admin login is disabled if ADMIN_PASSWORD is empty.
ADMIN_PASSWORD=
# Required. Use a long random secret; changing it logs out existing users.
ADMIN_SECRET=

SCANNER_REFRESH_MS=12000
SCANNER_NOTIONAL_USD=1000
SCANNER_MAX_SPREAD_PCT=25
SCANNER_MIN_PRICE=0.00000001

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5
OPENAI_BASE_URL=https://api.openai.com/v1
AI_USE_OPENAI=false
AI_MAX_REQUESTS_PER_WINDOW=10
AI_RATE_WINDOW_MS=600000

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
# Put the role ID for the Discord role named "VIP Member".
DISCORD_PREMIUM_ROLE_ID=
DISCORD_AUTO_JOIN=true
DISCORD_FREE_INVITE=https://discord.gg/zcXkSV34H

PAYMENT_DEFAULT_PROVIDER=payriff
PAYRIFF_BASE_URL=https://api.payriff.com
PAYRIFF_CREATE_PATH=/api/v3/orders
PAYRIFF_ORDER_PATH=/api/v3/orders/:orderId
PAYRIFF_SECRET_KEY=
PAYRIFF_CURRENCY=AZN
PAYRIFF_USD_TO_AZN_RATE=1.7
PAYRIFF_LANGUAGE=EN

# Only needed if future non-Payriff webhook providers are enabled.
WEBHOOK_SHARED_SECRET=
EPOINT_WEBHOOK_SECRET=
CRYPTO_WEBHOOK_SECRET=
CARD_WEBHOOK_SECRET=
EPOINT_PRIVATE_KEY=
CRYPTO_PAYMENT_WALLET=
CARD_PROVIDER_SECRET=
